@model Giftify.ViewModels.Account.RegisterVM

@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
/* ===== AUTH PAGE ===== */
.auth-page {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 3rem 1.5rem;
    background:
        radial-gradient(ellipse 60% 50% at 80% 0%, rgba(232,160,32,.06) 0%, transparent 55%),
        radial-gradient(ellipse 50% 60% at 20% 100%, rgba(15,61,46,.05) 0%, transparent 60%),
        var(--off-white);
}

.auth-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    width: 100%;
    max-width: 520px;
    overflow: hidden;
}
.auth-card-accent { height: 4px; background: linear-gradient(90deg, var(--green) 0%, var(--amber) 100%); }
.auth-card-body { padding: 2.5rem; }

.auth-logo { display:flex; align-items:center; justify-content:center; gap:.5rem; font-family:'Fraunces',serif; font-size:1.5rem; font-weight:500; color:var(--text); margin-bottom:1.75rem; text-decoration:none; }
.auth-logo:hover { color: var(--green); }
.auth-title { font-family:'Fraunces',serif; font-size:1.75rem; font-weight:500; color:var(--text); text-align:center; margin-bottom:.35rem; }
.auth-subtitle { font-size:13px; color:var(--text-muted); text-align:center; margin-bottom:2rem; }

/* Section heading */
.form-section-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--amber);
    display: flex;
    align-items: center;
    gap: .4rem;
    margin: 1.5rem 0 1rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--border);
}
.form-section-title:first-of-type { margin-top: 0; }

/* Form fields */
.gf-form-group { margin-bottom: 1.1rem; }
.gf-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.gf-label { display:block; font-size:13px; font-weight:600; color:var(--text); margin-bottom:.4rem; letter-spacing:.01em; }
.gf-label .optional { font-weight: 400; color: var(--text-muted); font-size: 11px; margin-left: .3rem; }
.gf-input {
    width: 100%;
    padding: .75rem 1rem;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    font-size: 14px;
    font-family: 'Satoshi', sans-serif;
    color: var(--text);
    background: var(--cream);
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    box-sizing: border-box;
}
.gf-input:focus { border-color: var(--green); background: var(--white); box-shadow: 0 0 0 3px rgba(15,61,46,.08); }
.gf-input::placeholder { color: var(--text-muted); }

textarea.gf-input { resize: vertical; min-height: 80px; }

/* Password */
.pw-wrap { position: relative; }
.pw-wrap .gf-input { padding-right: 2.8rem; }
.pw-toggle { position:absolute; right:.875rem; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--text-muted); font-size:.9rem; padding:0; transition:color .2s; }
.pw-toggle:hover { color: var(--green); }

/* Password strength */
.pw-strength { margin-top: .4rem; }
.pw-strength-bar { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
.pw-strength-fill { height: 100%; width: 0; border-radius: 2px; transition: width .3s, background .3s; }
.pw-strength-label { font-size: 11px; color: var(--text-muted); margin-top: .25rem; }

/* Profile image upload */
.file-upload-wrap {
    border: 2px dashed var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
    cursor: pointer;
    transition: border-color .2s, background .2s;
    background: var(--cream);
    position: relative;
}
.file-upload-wrap:hover { border-color: var(--green); background: rgba(15,61,46,.03); }
.file-upload-wrap input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
.file-upload-icon { font-size: 1.5rem; color: var(--text-muted); margin-bottom: .5rem; }
.file-upload-text { font-size: 13px; color: var(--text-muted); }
.file-upload-text strong { color: var(--green); }

/* Terms */
.gf-checkbox-label { display:flex; align-items:flex-start; gap:.6rem; font-size:13px; color:var(--text-mid); cursor:pointer; margin-bottom:1.5rem; }
.gf-checkbox-label input[type="checkbox"] { width:16px; height:16px; accent-color:var(--green); cursor:pointer; flex-shrink:0; margin-top:2px; }
.gf-checkbox-label a { color:var(--green); font-weight:600; text-decoration:none; }
.gf-checkbox-label a:hover { text-decoration: underline; }

/* Submit */
.btn-auth-submit {
    width: 100%;
    padding: .9rem;
    background: var(--green);
    color: var(--white);
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    font-family: 'Satoshi', sans-serif;
    cursor: pointer;
    transition: background .2s, transform .15s;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
}
.btn-auth-submit:hover { background: var(--green-mid); transform: translateY(-1px); }

/* Divider */
.auth-divider { display:flex; align-items:center; gap:1rem; margin-bottom:1.25rem; }
.auth-divider span { font-size:12px; color:var(--text-muted); white-space:nowrap; }
.auth-divider::before, .auth-divider::after { content:''; flex:1; height:1px; background:var(--border); }

/* Social */
.btn-social { width:100%; padding:.8rem; border:1.5px solid var(--border); border-radius:10px; font-size:14px; font-weight:600; font-family:'Satoshi',sans-serif; cursor:pointer; transition:all .2s; display:flex; align-items:center; justify-content:center; gap:.75rem; margin-bottom:.75rem; background:var(--white); color:var(--text); }
.btn-social:hover { border-color:var(--border-dark); background:var(--cream); }

.auth-switch { text-align:center; font-size:13px; color:var(--text-muted); margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border); }
.auth-switch a { color:var(--green); font-weight:700; text-decoration:none; }
.auth-switch a:hover { text-decoration:underline; }

.field-validation-error { font-size:12px; color:#e05454; display:block; margin-top:.25rem; }
</style>
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card-accent"></div>
        <div class="auth-card-body">

            <a class="auth-logo" asp-controller="Home" asp-action="Index">
                🎁 <span>Giftify</span>
            </a>

            <h1 class="auth-title">Create your account</h1>
            <p class="auth-subtitle">Join thousands of thoughtful gifters</p>

            <form asp-action="Register" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <!-- Account Info -->
                <div class="form-section-title"><i class="fa fa-user-circle"></i> Account Info</div>

                <div class="gf-form-row">
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" class="gf-input" placeholder="Jane Smith" />
                        <span asp-validation-for="FullName" class="field-validation-error"></span>
                    </div>
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="UserName">Username</label>
                        <input asp-for="UserName" class="gf-input" placeholder="janesmith" autocomplete="username" />
                        <span asp-validation-for="UserName" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="gf-form-group">
                    <label class="gf-label" asp-for="Email">Email Address</label>
                    <input asp-for="Email" class="gf-input" placeholder="jane@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="gf-form-row">
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="Password">Password</label>
                        <div class="pw-wrap">
                            <input asp-for="Password" class="gf-input" id="reg-pw" placeholder="Min. 6 characters" oninput="checkStrength(this.value)" autocomplete="new-password" />
                            <button type="button" class="pw-toggle" onclick="togglePw('reg-pw', this)" tabindex="-1">
                                <i class="fa fa-eye"></i>
                            </button>
                        </div>
                        <div class="pw-strength">
                            <div class="pw-strength-bar"><div class="pw-strength-fill" id="pw-fill"></div></div>
                            <div class="pw-strength-label" id="pw-label">Enter a password</div>
                        </div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="ConfirmPassword">Confirm Password</label>
                        <div class="pw-wrap">
                            <input asp-for="ConfirmPassword" class="gf-input" id="reg-cf" placeholder="Repeat password" autocomplete="new-password" />
                            <button type="button" class="pw-toggle" onclick="togglePw('reg-cf', this)" tabindex="-1">
                                <i class="fa fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <!-- Personal Details -->
                <div class="form-section-title"><i class="fa fa-id-card"></i> Personal Details</div>

                <div class="gf-form-row">
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="DateOfBirth">
                            Date of Birth <span class="optional">(optional)</span>
                        </label>
                        <input asp-for="DateOfBirth" type="date" class="gf-input" />
                        <span asp-validation-for="DateOfBirth" class="field-validation-error"></span>
                    </div>
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="ProfileImage">
                            Profile Photo <span class="optional">(optional)</span>
                        </label>
                        <div class="file-upload-wrap">
                            <input asp-for="ProfileImage" type="file" accept="image/*" onchange="showFileName(this)" />
                            <div class="file-upload-icon"><i class="fa fa-camera"></i></div>
                            <div class="file-upload-text" id="file-label">
                                <strong>Click to upload</strong> or drag & drop
                            </div>
                        </div>
                        <span asp-validation-for="ProfileImage" class="field-validation-error"></span>
                    </div>
                </div>

                <!-- Delivery Address -->
                <div class="form-section-title"><i class="fa fa-map-marker-alt"></i> Delivery Address <span style="font-weight:400;color:var(--text-muted);font-size:10px;margin-left:.3rem;text-transform:none;letter-spacing:0">(optional)</span></div>

                <div class="gf-form-row">
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="City">City</label>
                        <input asp-for="City" class="gf-input" placeholder="Cairo" />
                        <span asp-validation-for="City" class="field-validation-error"></span>
                    </div>
                    <div class="gf-form-group">
                        <label class="gf-label" asp-for="Street">Street</label>
                        <input asp-for="Street" class="gf-input" placeholder="123 Main Street" />
                        <span asp-validation-for="Street" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="gf-form-group">
                    <label class="gf-label" asp-for="Building">Building / Apt</label>
                    <input asp-for="Building" class="gf-input" placeholder="Building 5, Floor 3, Apt 12" />
                    <span asp-validation-for="Building" class="field-validation-error"></span>
                </div>

                <div class="gf-form-group">
                    <label class="gf-label" asp-for="AddressNotes">Delivery Notes <span class="optional">(optional)</span></label>
                    <textarea asp-for="AddressNotes" class="gf-input" placeholder="Ring the bell twice, leave at door, etc."></textarea>
                    <span asp-validation-for="AddressNotes" class="field-validation-error"></span>
                </div>

                <!-- Terms -->
                <label class="gf-checkbox-label">
                    <input type="checkbox" id="r-terms" required />
                    I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
                </label>

                <button type="submit" class="btn-auth-submit">
                    <i class="fa fa-gift"></i> Create My Account
                </button>
            </form>

            <div class="auth-divider"><span>or register with</span></div>

            <form asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" name="provider" value="Google" class="btn-social">
                    <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.7-6.7C35.8 2.5 30.3 0 24 0 14.7 0 6.7 5.5 2.9 13.6l7.8 6C12.4 13.1 17.8 9.5 24 9.5z"/><path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8c4.4-4.1 7.1-10.1 7.1-17z"/><path fill="#FBBC05" d="M10.7 28.5c-.5-1.5-.8-3-.8-4.5s.3-3 .8-4.5l-7.8-6C1.1 16.5 0 20.1 0 24s1.1 7.5 2.9 10.5l7.8-6z"/><path fill="#34A853" d="M24 48c6.3 0 11.6-2.1 15.5-5.6l-7.5-5.8c-2.1 1.4-4.8 2.2-8 2.2-6.2 0-11.5-3.6-13.3-8.8l-7.8 6C6.7 42.5 14.7 48 24 48z"/></svg>
                    Continue with Google
                </button>
                <button type="submit" name="provider" value="Facebook" class="btn-social">
                    <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#1877F2" d="M48 24C48 10.7 37.3 0 24 0S0 10.7 0 24c0 12 8.8 21.9 20.3 23.7V30.9h-6.1V24h6.1v-5.3c0-6 3.6-9.3 9-9.3 2.6 0 5.4.5 5.4.5v5.9h-3c-3 0-3.9 1.9-3.9 3.8V24h6.6l-1.1 6.9h-5.6V47.7C39.2 45.9 48 36 48 24z"/></svg>
                    Continue with Facebook
                </button>
            </form>

            <div class="auth-switch">
                Already have an account?
                <a asp-controller="Account" asp-action="Login">Sign in here</a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePw(id, btn) {
            var inp = document.getElementById(id);
            var isText = inp.type === 'text';
            inp.type = isText ? 'password' : 'text';
            btn.innerHTML = isText ? '<i class="fa fa-eye"></i>' : '<i class="fa fa-eye-slash"></i>';
        }

        function checkStrength(val) {
            var fill = document.getElementById('pw-fill');
            var label = document.getElementById('pw-label');
            var s = 0;
            if (val.length >= 8) s++;
            if (/[A-Z]/.test(val)) s++;
            if (/[0-9]/.test(val)) s++;
            if (/[^A-Za-z0-9]/.test(val)) s++;
            var pct = [0, 25, 50, 75, 100][s];
            var colors = ['#ccc', '#e24b4a', '#ef9f27', '#63a522', '#0f3d2e'];
            var labels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
            fill.style.width = pct + '%';
            fill.style.background = colors[s];
            label.textContent = val.length === 0 ? 'Enter a password' : labels[s] + ' password';
        }

        function showFileName(input) {
            var label = document.getElementById('file-label');
            if (input.files && input.files[0]) {
                label.innerHTML = '<strong>' + input.files[0].name + '</strong>';
            }
        }
    </script>
}
