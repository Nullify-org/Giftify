@using Giftify.Models
@model Occasion
@{
    ViewData["Title"] = "Add Occasion";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none" style="font-size:.85rem;">
        <i class="bi bi-arrow-left me-1"></i>Back to Occasions
    </a>
</div>

<div class="stat-card" style="max-width:540px;">
    <h5 class="fw-bold mb-4" style="color:#1a1a2e;">Add Occasion</h5>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control rounded-3" placeholder="e.g. Birthday" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea asp-for="Description" class="form-control rounded-3" rows="3"></textarea>
        </div>
        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label class="form-check-label">Active</label>
            </div>
        </div>
        <button type="submit" class="btn btn-dark rounded-pill px-5">
            <i class="bi bi-plus-lg me-1"></i> Create
        </button>
    </form>
</div>
