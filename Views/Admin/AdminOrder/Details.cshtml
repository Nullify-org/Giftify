@using Giftify.Models
@model Order
@{
    ViewData["Title"] = $"Order #{Model.Id}";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var statuses = ViewBag.Statuses as string[] ?? Array.Empty<string>();
    var badgeClass = Model.Status switch {
        "Delivered"  => "bg-success-subtle text-success",
        "Shipped"    => "bg-primary-subtle text-primary",
        "Processing" => "bg-warning-subtle text-warning",
        "Cancelled"  => "bg-danger-subtle text-danger",
        _            => "bg-secondary-subtle text-secondary"
    };
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none" style="font-size:.85rem;">
        <i class="bi bi-arrow-left me-1"></i>Back to Orders
    </a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    <!-- Order Info -->
    <div class="col-lg-8">
        <div class="stat-card mb-3">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5 class="fw-bold mb-0" style="color:#1a1a2e;">Order #@Model.Id</h5>
                    <span class="text-muted" style="font-size:.82rem;">@Model.OrderDate.ToString("MMMM d, yyyy — h:mm tt")</span>
                </div>
                <span class="badge @badgeClass rounded-pill px-3 py-2">@Model.Status</span>
            </div>

            <table class="table align-middle mb-0" style="font-size:.9rem;">
                <thead style="background:#f8f9fc;">
                    <tr>
                        <th class="border-0 text-muted">Product</th>
                        <th class="border-0 text-muted">Qty</th>
                        <th class="border-0 text-muted text-end">Price</th>
                        <th class="border-0 text-muted text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Product?.Name</td>
                            <td>@item.Quantity</td>
                            <td class="text-end">@item.UnitPrice.ToString("N0") EGP</td>
                            <td class="text-end fw-semibold">@((item.UnitPrice * item.Quantity).ToString("N0")) EGP</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold border-0 pt-3">Total</td>
                        <td class="text-end fw-bold border-0 pt-3" style="font-size:1.05rem;color:#e94560;">
                            @Model.TotalAmount.ToString("N0") EGP
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>

        @if (!string.IsNullOrEmpty(Model.GiftMessage))
        {
            <div class="stat-card">
                <h6 class="fw-semibold mb-2"><i class="bi bi-gift me-2 text-danger"></i>Gift Message</h6>
                <p class="mb-0 text-muted">@Model.GiftMessage</p>
            </div>
        }
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Customer -->
        <div class="stat-card mb-3">
            <h6 class="fw-bold mb-3" style="color:#1a1a2e;">Customer</h6>
            <div class="fw-semibold">@(Model.User?.FullName ?? "—")</div>
            <div class="text-muted small">@Model.User?.Email</div>
            <div class="text-muted small">@Model.User?.UserName</div>
        </div>

        <!-- Shipping -->
        <div class="stat-card mb-3">
            <h6 class="fw-bold mb-3" style="color:#1a1a2e;">Shipping Address</h6>
            <div class="text-muted small">@Model.ShippingAddress</div>
        </div>

        <!-- Payment -->
        @if (Model.Payment is not null)
        {
            <div class="stat-card mb-3">
                <h6 class="fw-bold mb-3" style="color:#1a1a2e;">Payment</h6>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Method</span>
                    <span class="fw-semibold">@Model.Payment.PaymentMethod</span>
                </div>
                <div class="d-flex justify-content-between small mt-1">
                    <span class="text-muted">Status</span>
                    <span class="fw-semibold">@Model.Payment.PaymentStatus</span>
                </div>
            </div>
        }

        <!-- Update Status -->
        <div class="stat-card">
            <h6 class="fw-bold mb-3" style="color:#1a1a2e;">Update Status</h6>
            <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <select name="status" class="form-select form-select-sm rounded-3 mb-2">
                    @foreach (var s in statuses)
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
                <button type="submit" class="btn btn-dark btn-sm rounded-pill w-100">
                    <i class="bi bi-arrow-repeat me-1"></i>Update
                </button>
            </form>
        </div>
    </div>
</div>
