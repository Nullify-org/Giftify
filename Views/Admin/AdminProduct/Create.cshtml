@using Giftify.ViewModels.Admin
@model AdminProductCreateVM

@{
    ViewData["Title"] = "Create Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4" style="max-width:720px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h2 class="fw-bold mb-0">New Product</h2>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>

            <div class="row g-3">

                <div class="col-12">
                    <label asp-for="Name" class="form-label fw-semibold">Product Name</label>
                    <input asp-for="Name" class="form-control rounded-3" placeholder="e.g. Luxury Gift Box" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control rounded-3" rows="3"
                              placeholder="Short description..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Price" class="form-label fw-semibold">Price (EGP)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control rounded-3" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Stock" class="form-label fw-semibold">Stock Quantity</label>
                    <input asp-for="Stock" type="number" class="form-control rounded-3" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-balloon-heart me-1"></i>Occasions
                        <span class="text-muted fw-normal small ms-1">(optional)</span>
                    </label>
                    <div class="d-flex flex-wrap gap-2 p-3 border rounded-3 bg-light" style="min-height:52px;">
                        @if (ViewBag.Occasions != null)
                        {
                            foreach (var occ in (IEnumerable<Giftify.Models.Occasion>)ViewBag.Occasions)
                            {
                                var isChecked = ((List<int>)ViewBag.SelectedOccasionIds).Contains(occ.Id);
                                <div class="form-check form-check-inline m-0">
                                    <input class="form-check-input" type="checkbox"
                                           name="SelectedOccasionIds" value="@occ.Id"
                                           id="occ_@occ.Id" @(isChecked ? "checked" : "") />
                                    <label class="form-check-label badge bg-secondary-subtle text-secondary fw-normal px-2"
                                           for="occ_@occ.Id" style="cursor:pointer;">@occ.Name</label>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-muted small">No occasions available.</span>
                        }
                    </div>
                </div>

                <div class="col-md-8">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                            class="form-select rounded-3">
                        <option value="">— Select category —</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="col-md-4 d-flex align-items-center gap-2 pt-4">
                    <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActiveCheck" />
                    <label class="form-check-label fw-semibold" for="isActiveCheck">Active</label>
                </div>

                <div class="col-12">
                    <label asp-for="ImageFile" class="form-label fw-semibold">Product Image</label>
                    <input asp-for="ImageFile" type="file" class="form-control rounded-3"
                           accept=".jpg,.jpeg,.png,.webp,.gif"
                           onchange="previewImage(this)" />
                    <div class="mt-2">
                        <img id="imgPreview" src="#" alt="Preview"
                             class="rounded-3 d-none"
                             style="max-height:160px;object-fit:cover;" />
                    </div>
                </div>

            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-dark rounded-pill px-4">
                    <i class="bi bi-check-lg me-1"></i> Create Product
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImage(input) {
            const preview = document.getElementById('imgPreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
