@model Giftify.ViewModels.Admin.AdminDashboardVM

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <!-- Revenue -->
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon" style="background:#fff3f5;">
                    <i class="bi bi-currency-dollar" style="color:#e94560;"></i>
                </div>
                <span class="badge bg-success-subtle text-success rounded-pill" style="font-size:.7rem;">Revenue</span>
            </div>
            <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;">
                @Model.TotalRevenue.ToString("N0") <span style="font-size:.9rem;font-weight:500;color:#888;">EGP</span>
            </div>
            <div style="font-size:.8rem;color:#888;margin-top:4px;">Total earned</div>
        </div>
    </div>
    <!-- Orders -->
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon" style="background:#f0f7ff;">
                    <i class="bi bi-bag-check-fill" style="color:#3b82f6;"></i>
                </div>
                <span class="badge bg-primary-subtle text-primary rounded-pill" style="font-size:.7rem;">Orders</span>
            </div>
            <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;">@Model.TotalOrders</div>
            <div style="font-size:.8rem;color:#888;margin-top:4px;">@Model.PendingOrders pending</div>
        </div>
    </div>
    <!-- Products -->
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon" style="background:#f0fff4;">
                    <i class="bi bi-box-seam-fill" style="color:#22c55e;"></i>
                </div>
                <span class="badge bg-success-subtle text-success rounded-pill" style="font-size:.7rem;">Products</span>
            </div>
            <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;">@Model.TotalProducts</div>
            <div style="font-size:.8rem;color:#888;margin-top:4px;">In catalog</div>
        </div>
    </div>
    <!-- Users -->
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon" style="background:#fffbeb;">
                    <i class="bi bi-people-fill" style="color:#f59e0b;"></i>
                </div>
                <span class="badge bg-warning-subtle text-warning rounded-pill" style="font-size:.7rem;">Users</span>
            </div>
            <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;">@Model.TotalUsers</div>
            <div style="font-size:.8rem;color:#888;margin-top:4px;">Registered</div>
        </div>
    </div>
</div>

<!-- Quick Actions + Order Status Row -->
<div class="row g-3 mb-4">
    <!-- Quick Actions -->
    <div class="col-lg-5">
        <div class="stat-card h-100">
            <h6 class="fw-bold mb-3" style="color:#1a1a2e;">Quick Actions</h6>
            <div class="d-grid gap-2">
                <a asp-controller="AdminProduct" asp-action="Create"
                   class="btn btn-dark rounded-3 text-start">
                    <i class="bi bi-plus-circle me-2"></i>Add New Product
                </a>
                <a asp-controller="AdminCategory" asp-action="Create"
                   class="btn btn-outline-dark rounded-3 text-start">
                    <i class="bi bi-tag me-2"></i>Add Category
                </a>
                <a asp-controller="AdminOccasion" asp-action="Create"
                   class="btn btn-outline-dark rounded-3 text-start">
                    <i class="bi bi-calendar-plus me-2"></i>Add Occasion
                </a>
                <a asp-controller="AdminUser" asp-action="Create"
                   class="btn btn-outline-dark rounded-3 text-start">
                    <i class="bi bi-person-plus me-2"></i>Add User
                </a>
            </div>
        </div>
    </div>

    <!-- Order Status Breakdown -->
    <div class="col-lg-7">
        <div class="stat-card h-100">
            <h6 class="fw-bold mb-3" style="color:#1a1a2e;">Order Status</h6>
            @{
                int total = Model.TotalOrders > 0 ? Model.TotalOrders : 1;
            }
            @foreach (var item in new[] {
                new { Label = "Pending",    Count = Model.PendingOrders,    Color = "#f59e0b" },
                new { Label = "Processing", Count = Model.ProcessingOrders, Color = "#3b82f6" },
                new { Label = "Shipped",    Count = Model.ShippedOrders,    Color = "#8b5cf6" },
                new { Label = "Delivered",  Count = Model.DeliveredOrders,  Color = "#22c55e" },
            })
            {
                int pct = (item.Count * 100) / total;
                <div class="mb-2">
                    <div class="d-flex justify-content-between" style="font-size:.82rem;">
                        <span>@item.Label</span><span class="fw-semibold">@item.Count</span>
                    </div>
                    <div style="background:#f0f0f0;border-radius:6px;height:6px;">
                        <div style="background:@item.Color;width:@(pct)%;height:6px;border-radius:6px;transition:width .4s;"></div>
                    </div>
                </div>
            }
            <div class="mt-3">
                <a asp-controller="AdminOrder" asp-action="Index"
                   class="btn btn-sm btn-outline-dark rounded-pill">
                    View All Orders <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="stat-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0" style="color:#1a1a2e;">Recent Orders</h6>
        <a asp-controller="AdminOrder" asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill">
            View All
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" style="font-size:.88rem;">
            <thead style="background:#f8f9fc;">
                <tr>
                    <th class="border-0 fw-semibold text-muted">#</th>
                    <th class="border-0 fw-semibold text-muted">Customer</th>
                    <th class="border-0 fw-semibold text-muted">Date</th>
                    <th class="border-0 fw-semibold text-muted">Amount</th>
                    <th class="border-0 fw-semibold text-muted">Status</th>
                    <th class="border-0"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    var badgeClass = o.Status switch {
                        "Delivered"  => "bg-success-subtle text-success",
                        "Shipped"    => "bg-primary-subtle text-primary",
                        "Processing" => "bg-warning-subtle text-warning",
                        "Cancelled"  => "bg-danger-subtle text-danger",
                        _            => "bg-secondary-subtle text-secondary"
                    };
                    <tr>
                        <td class="text-muted">#@o.Id</td>
                        <td class="fw-semibold">@(o.User?.FullName ?? o.User?.UserName ?? "—")</td>
                        <td class="text-muted">@o.OrderDate.ToString("MMM d, yyyy")</td>
                        <td class="fw-semibold">@o.TotalAmount.ToString("N0") EGP</td>
                        <td><span class="badge @badgeClass rounded-pill">@o.Status</span></td>
                        <td class="text-end">
                            <a asp-controller="AdminOrder" asp-action="Details" asp-route-id="@o.Id"
                               class="btn btn-sm btn-outline-secondary rounded-pill">Details</a>
                        </td>
                    </tr>
                }
                @if (!Model.RecentOrders.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No orders yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
