@using Giftify.ViewModels.Cart
@model CartVM

@{
    ViewData["Title"] = "Your Cart";
    Layout = "_Layout";
}

<div class="container" style="max-width:860px;margin:3rem auto;padding:0 24px;">

    <h1 style="font-family:'Fraunces',serif;font-size:2rem;font-weight:500;margin-bottom:2rem;">
        🛒 Your Cart
    </h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div style="text-align:center;padding:60px 0;color:#888;">
            <div style="font-size:4rem;margin-bottom:1rem;">🎁</div>
            <p style="font-size:1.1rem;">Your cart is empty.</p>
            <a asp-controller="Products" asp-action="Index"
               style="display:inline-block;margin-top:1rem;background:#0F3D2E;color:#fff;padding:.75rem 2rem;border-radius:10px;text-decoration:none;font-weight:600;">
                Shop Gifts
            </a>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:1rem;margin-bottom:2rem;">

            @foreach (var item in Model.Items)
            {
                <div style="display:flex;align-items:center;gap:1.25rem;background:#fff;border-radius:14px;border:1px solid #e2ddd4;padding:1rem 1.25rem;">

                    <div style="width:80px;height:80px;border-radius:10px;overflow:hidden;flex-shrink:0;background:#f7f4ee;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.ProductName"
                                 style="width:100%;height:100%;object-fit:cover;" />
                        }
                        else
                        {
                            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:2rem;">🎁</div>
                        }
                    </div>

                    <div style="flex:1;">
                        <div style="font-weight:700;font-size:.95rem;color:#1c1c1a;">@item.ProductName</div>
                        <div style="font-size:.9rem;color:#8a8a7a;margin-top:3px;">
                            @item.UnitPrice.ToString("C") each
                        </div>
                    </div>

                    <form asp-controller="Cart" asp-action="UpdateQuantity" method="post"
                          style="display:flex;align-items:center;gap:.5rem;">
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <input type="number" name="quantity" value="@item.Quantity" min="1" max="99"
                               style="width:60px;text-align:center;border:1px solid #ddd;border-radius:8px;padding:.3rem .5rem;font-size:.9rem;" />
                        <button type="submit"
                                style="background:#f3f4f6;border:1px solid #ddd;border-radius:8px;padding:.35rem .75rem;font-size:.8rem;cursor:pointer;font-weight:600;">
                            Update
                        </button>
                    </form>

                    <!-- Line total -->
                    <div style="font-family:'Fraunces',serif;font-size:1.05rem;font-weight:500;min-width:80px;text-align:right;">
                        @item.LineTotal.ToString("C")
                    </div>

                    <!-- Remove -->
                    <form asp-controller="Cart" asp-action="Remove" method="post">
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <button type="submit"
                                style="background:none;border:none;cursor:pointer;color:#ef4444;font-size:1.1rem;padding:.25rem;"
                                title="Remove">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>

                </div>
            }

        </div>

        <div style="background:#0F3D2E;border-radius:16px;padding:1.5rem 2rem;color:#fff;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
            <div>
                <div style="font-size:.85rem;color:rgba(255,255,255,.6);margin-bottom:.25rem;">
                    @Model.TotalItems item(s)
                </div>
                <div style="font-family:'Fraunces',serif;font-size:1.9rem;font-weight:500;">
                    @Model.Subtotal.ToString("C")
                </div>
            </div>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <form asp-controller="Cart" asp-action="Clear" method="post">
                    <button type="submit"
                            style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.25);color:#fff;padding:.7rem 1.5rem;border-radius:10px;cursor:pointer;font-weight:600;font-size:.9rem;">
                        Clear Cart
                    </button>
                </form>
                <a href="#"
                   style="background:#E8A020;color:#1c1c1a;padding:.7rem 1.75rem;border-radius:10px;font-weight:700;font-size:.9rem;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;">
                    Checkout &rarr;
                </a>
            </div>
        </div>
    }

</div>
