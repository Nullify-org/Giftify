@using Giftify.ViewModels.Categories
@model CategoryLandingVM

@{
    ViewData["Title"] = $"{Model.CategoryName} — Giftify";
}

@* ═══════════════════════  CATEGORY HEADER  ═══════════════════════ *@
<section class="gfy-cat-hero py-5 mb-4">
    <div class="container-fluid px-lg-5">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">
                        <i class="bi bi-house me-1"></i>Home
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Products" asp-action="Index" class="text-decoration-none text-muted">Products</a>
                </li>
                <li class="breadcrumb-item active fw-semibold">@Model.CategoryName</li>
            </ol>
        </nav>

        <div class="d-flex align-items-start gap-4 flex-wrap">
            <div class="gfy-cat-hero__icon-wrap">
                <i class="bi bi-gift fs-1 text-dark"></i>
            </div>
            <div>
                <h1 class="fw-bold mb-1">@Model.CategoryName</h1>
                @if (!string.IsNullOrEmpty(Model.CategoryDescription))
                {
                    <p class="text-muted fs-5 mb-2">@Model.CategoryDescription</p>
                }
                <span class="badge rounded-pill bg-dark">@Model.TotalProducts products</span>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════  MAIN CONTENT  ═══════════════════════════ *@
<div class="container-fluid px-lg-5 pb-5">
    <div class="row g-4">

        @* ── Sidebar ─────────────────────────────────────────────── *@
        <aside class="col-lg-3">
            @if (Model.RelatedCategories.Any())
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-header bg-dark text-white fw-bold py-3 rounded-top-4">
                        <i class="bi bi-grid-3x3-gap me-2"></i>Other Categories
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush rounded-bottom-4">
                            @foreach (var related in Model.RelatedCategories)
                            {
                                bool isCurrent = related.Id == Model.CategoryId;
                                <li class="list-group-item list-group-item-action
                                           @(isCurrent ? "active fw-bold" : "") px-4 py-3">
                                    <a asp-controller="Category" asp-action="Index"
                                       asp-route-id="@related.Id"
                                       class="d-flex justify-content-between align-items-center text-decoration-none
                                              @(isCurrent ? "text-white" : "text-dark")">
                                        @related.Name
                                        <span class="badge @(isCurrent ? "bg-white text-dark" : "bg-secondary-subtle text-secondary") rounded-pill small">
                                            @related.ProductCount
                                        </span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            @* Quick filter link back to full products *@
            <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@Model.CategoryId"
               class="btn btn-outline-dark w-100 rounded-pill py-2">
                <i class="bi bi-filter-left me-2"></i>Advanced Filters
            </a>
        </aside>

        @* ── Product Grid ─────────────────────────────────────────── *@
        <main class="col-lg-9">

            @* Results bar *@
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                <p class="text-muted small mb-0">
                    Showing <strong>@Model.Products.Count</strong> of
                    <strong>@Model.TotalProducts</strong> products in
                    <strong>@Model.CategoryName</strong>
                </p>
            </div>

            @if (!Model.Products.Any())
            {
                @* Empty state *@
                <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                    <i class="bi bi-box-seam display-1 text-secondary"></i>
                    <h4 class="mt-4 fw-bold">No products yet</h4>
                    <p class="text-muted">We're working on adding more to this category.</p>
                    <a asp-controller="Products" asp-action="Index"
                       class="btn btn-dark rounded-pill px-4 mt-2">
                        Browse all products
                    </a>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-xl-3 g-4">
                    @foreach (var product in Model.Products)
                    {
                        <div class="col">
                            <div class="gfy-cat-product-card card h-100 border-0 rounded-4 overflow-hidden shadow-sm">

                                @* Image *@
                                <div class="gfy-cat-product-card__img-wrap position-relative">
                                    <a asp-controller="Products" asp-action="Details"
                                       asp-route-id="@product.Id">
                                        <img src="@product.ImageUrl"
                                             alt="@product.Name"
                                             class="card-img-top gfy-cat-product-card__img"
                                             onerror="this.src='/images/default-product.png'">
                                    </a>

                                    @* Stock indicator *@
                                    @if (!product.IsInStock)
                                    {
                                        <span class="badge bg-danger position-absolute top-0 start-0 m-3 rounded-pill">
                                            Out of stock
                                        </span>
                                    }
                                    else if (product.Stock <= 5)
                                    {
                                        <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-3 rounded-pill">
                                            Only @product.Stock left
                                        </span>
                                    }

                                    @* Wishlist *@
                                    <button class="gfy-cat-product-card__wishlist btn btn-light btn-sm rounded-circle shadow-sm"
                                            aria-label="Add to wishlist">
                                        <i class="bi bi-heart"></i>
                                    </button>
                                </div>

                                @* Body *@
                                <div class="card-body p-3 d-flex flex-column">
                                    <h6 class="fw-bold text-dark mb-1 text-truncate">@product.Name</h6>

                                    <div class="mt-auto pt-3">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="fw-bold fs-5 text-dark">
                                                @product.Price.ToString("N0") EGP
                                            </span>
                                            @if (product.IsInStock)
                                            {
                                                <span class="badge rounded-pill bg-success-subtle text-success small">
                                                    In stock
                                                </span>
                                            }
                                        </div>

                                        <div class="d-grid gap-2">
                                            <button class="btn btn-dark rounded-pill btn-sm py-2
                                                           @(product.IsInStock ? "" : "disabled")"
                                                    data-product-id="@product.Id"
                                                    @(product.IsInStock ? "" : "disabled")>
                                                <i class="bi bi-cart-plus me-1"></i> Add to Cart
                                            </button>
                                            <a asp-controller="Products" asp-action="Details"
                                               asp-route-id="@product.Id"
                                               class="btn btn-outline-secondary btn-sm rounded-pill border-0">
                                                View Details
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>

@section Scripts {
<style>
/* Category hero */
.gfy-cat-hero {
    background:linear-gradient(135deg,#fafafa 0%,#f0ece8 100%);
    border-bottom:1px solid #ede8e3;
}
.gfy-cat-hero__icon-wrap {
    width:72px; height:72px; border-radius:20px;
    background:#fff; border:1px solid #e8e3de;
    display:flex; align-items:center; justify-content:center;
    flex-shrink:0;
}

/* Category product cards */
.gfy-cat-product-card { transition:transform .18s, box-shadow .18s; }
.gfy-cat-product-card:hover { transform:translateY(-4px); box-shadow:0 12px 32px rgba(0,0,0,.1) !important; }
.gfy-cat-product-card__img-wrap { overflow:hidden; }
.gfy-cat-product-card__img {
    height:220px; object-fit:cover; width:100%;
    transition:transform .3s ease;
}
.gfy-cat-product-card:hover .gfy-cat-product-card__img { transform:scale(1.04); }
.gfy-cat-product-card__wishlist {
    position:absolute; top:10px; right:10px;
    width:34px; height:34px; padding:0;
    display:flex; align-items:center; justify-content:center;
    transition:all .15s;
}
.gfy-cat-product-card__wishlist:hover { background:#1a1a1a; color:#fff; }

/* Active sidebar item override */
.list-group-item.active { background-color:#1a1a1a; border-color:#1a1a1a; }
</style>
}
