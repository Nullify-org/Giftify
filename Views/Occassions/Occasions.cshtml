@using Giftify.ViewModels.Occasions

@model IEnumerable<OccasionVM>

@{
    ViewData["Title"] = "All Occasions";
    Layout = "_Layout";
}

@section Scripts {
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/Home/home.css" rel="stylesheet" />
}

<section class="occ-browse" style="padding: 3.5rem 0;">
    <div class="container">

        <div class="sec-hd">
            <div>
                <div class="sec-tag"><i class="fa fa-calendar-alt"></i> All Occasions</div>
                <h2>Shop by Occasion</h2>
            </div>
            <a asp-controller="Home" asp-action="Index" class="see-all">
                &larr; Back to Home
            </a>
        </div>

        @if (Model != null && Model.Any())
        {
            var occasionData = new (string emoji, string gradient)[]
            {
                ("\U0001f382", "linear-gradient(135deg,#f093fb,#f5576c)"),
                ("\U0001f48d", "linear-gradient(135deg,#4facfe,#00f2fe)"),
                ("\u2764\ufe0f",  "linear-gradient(135deg,#f77062,#fe5196)"),
                ("\U0001f37c", "linear-gradient(135deg,#43e97b,#38f9d7)"),
                ("\U0001f393", "linear-gradient(135deg,#f6d365,#fda085)"),
                ("\U0001f384", "linear-gradient(135deg,#0f9b58,#00bf72)"),
                ("\U0001f339", "linear-gradient(135deg,#ee0979,#ff6a00)"),
                ("\U0001f3e1", "linear-gradient(135deg,#a18cd1,#fbc2eb)"),
                ("\U0001f381", "linear-gradient(135deg,#E8A020,#F5C55A)"),
                ("\U0001f389", "linear-gradient(135deg,#6a11cb,#2575fc)"),
                ("\U0001f91d", "linear-gradient(135deg,#11998e,#38ef7d)"),
                ("\U0001f3c6", "linear-gradient(135deg,#f7971e,#ffd200)")
            };

            int di = 0;

            <div class="occ-cards" style="grid-template-columns: repeat(4,1fr);">
                @foreach (var occ in Model)
                {
                    var (emoji, gradient) = di < occasionData.Length
                        ? occasionData[di]
                        : ("\U0001f381", "linear-gradient(135deg,#E8A020,#F5C55A)");
                    di++;

                    <a asp-controller="Products"
                       asp-action="Index"
                       asp-route-occasionId="@occ.Id"
                       class="occ-card">

                        <div class="occ-card-bg" style="background:@gradient"></div>
                        <div class="occ-card-overlay"></div>

                        <div class="occ-card-body">
                            <span class="occ-card-emoji">@emoji</span>
                            <span class="occ-card-name">@occ.Name</span>
                        </div>

                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty">
                <div class="empty-icon">🎉</div>
                <p>No occasions found.</p>
            </div>
        }

    </div>
</section>
