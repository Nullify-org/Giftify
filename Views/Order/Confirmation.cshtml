@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="container py-5 text-center" style="max-width:520px;">
    <div class="mb-4">
        <span style="font-size:4rem;">🎉</span>
    </div>
    <h2 class="fw-bold mb-2">Order Placed!</h2>
    <p class="text-muted mb-1">
        Your order <strong>#@ViewBag.OrderId</strong> has been received and is being processed.
    </p>
    <p class="text-muted mb-4">You'll receive a confirmation once it ships.</p>

    <div class="d-flex justify-content-center gap-3">
        <a asp-action="MyOrders" class="btn btn-dark rounded-pill px-4">
            <i class="bi bi-bag-check me-1"></i> My Orders
        </a>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-bag-heart me-1"></i> Continue Shopping
        </a>
    </div>
</div>
