@using Giftify.ViewModels.Products

@model ProductDetailsVM

@{
    ViewData["Title"] = "Details";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active">@Model.Category.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-6">
            <div class="main-image mb-3">
                @if (Model.ImageUrls.Any())
                {
                    <img src="@Model.ImageUrls[0]" id="mainImg" class="img-fluid rounded shadow w-100" style="height: 450px; object-fit: cover;" alt="@Model.Name">
                }
                else
                {
                    <img src="/images/default-product.png" class="img-fluid rounded shadow" alt="Default Image">
                }
            </div>

            <div class="d-flex gap-2">
                @foreach (var imgUrl in Model.ImageUrls)
                {
                    <img src="@imgUrl" class="img-thumbnail" style="width: 80px; height: 80px; cursor: pointer; object-fit: cover;"
                         onclick="document.getElementById('mainImg').src='@imgUrl'">
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="ps-md-4">
                <h1 class="display-5 fw-bold">@Model.Name</h1>

                <div class="mb-3">
                    @foreach (var occasion in Model.Occasions)
                    {
                        <a asp-action="Index" asp-route-occasionId="@occasion.Id" class="badge rounded-pill bg-primary me-1 text-decoration-none">
                            @occasion.Name
                        </a>
                    }
                </div>

                <h3 class="text-success fw-bold mb-3">@Model.Price.ToString("C2")</h3>

                <hr>

                <div class="mb-4">
                    <h5>Description</h5>
                    <p class="text-muted">@Model.Description</p>
                </div>

                <div class="mb-4">
                    <strong>Category:</strong>
                    <a asp-action="Index" asp-route-categoryId="@Model.Category.Id" class="text-decoration-none">@Model.Category.Name</a>
                    <br>
                    <strong>Availability:</strong>
                    @if (Model.StockQuantity > 0)
                    {
                        <span class="badge bg-success">In Stock (@Model.StockQuantity)</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Out of Stock</span>
                    }
                </div>

                <div class="d-grid gap-2 d-md-block">
                    <button class="btn btn-dark btn-lg px-5" type="button">
                        <i class="bi bi-cart-plus"></i> Add to Cart
                    </button>

                </div>

                <div class="mt-4">
                    <a asp-action="Index" class="text-decoration-none text-muted">
                        <i class="bi bi-arrow-left"></i> Back to Products Page
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeImage(url) {
            document.getElementById('mainImg').src = url;
        }
    </script>
}