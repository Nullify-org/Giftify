@model Giftify.ViewModels.Products.EditProductVM

@{
    ViewData["Title"] = "Edit";
    var categoryList = new SelectList(Model.Categories, "Id", "Name");
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Edit Gift Product</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label fw-bold">Category</label>
                        <select asp-for="CategoryId" asp-items="categoryList" class="form-select">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="col-12 mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Stock" class="form-label fw-bold"></label>
                        <input asp-for="Stock" class="form-control" type="number" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>

                    @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                    {
                        <div class="col-12 mb-3">
                            <label class="form-label fw-bold">Current Product Images</label>
                            <div class="d-flex flex-wrap gap-2 p-3 border rounded bg-light">
                                @foreach (var img in Model.ExistingImages)
                                {
                                    <div class="position-relative" id="img-wrapper-@img.Id">
                                        <img src="@img.Url" class="rounded shadow-sm border"
                                             style="width: 120px; height: 120px; object-fit: cover;" />
                                        <button type="button" class="btn-delete position-absolute d-flex justify-content-center align-items-center"
                                                onclick="deleteImage(@img.Id)"
                                                style="width: 25px; height: 25px; right: 0; border-radius: 50%; top: 3px; right: 3px;">
                                            X
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="col-12 mb-3">
                        <label asp-for="Images" class="form-label fw-bold">Upload New Images</label>
                        <input asp-for="Images" type="file" class="form-control" multiple accept="image/*" />
                        <small class="text-muted text-primary fw-bold">Note: New images will be added to existing ones.</small>
                    </div>

                    <div class="col-12 mb-4">
                        <label class="form-label fw-bold d-block">Target Occasions</label>
                        <div class="d-flex flex-wrap gap-3 p-3 bg-light rounded">
                            @foreach (var occasion in Model.Occasions)
                            {
                                <div class="form-check">
                                    <input type="checkbox"
                                           name="SelectedOccasionIds"
                                           value="@occasion.Id"
                                           id="occ_@occasion.Id"
                                           class="form-check-input"
                                           checked="@(Model.SelectedOccasionIds.Contains(occasion.Id))" />
                                    <label class="form-check-label" for="occ_@occasion.Id">@occasion.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-5 rounded-pill">Confirm Update</button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        async function deleteImage(imageId) {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: "This image will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/Products/DeleteImage/${imageId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    });

                    const data = await response.json();

                    if (data.success) {
                        const imgElement = document.querySelector(`button[onclick="deleteImage(${imageId})"]`).parentElement;
                        imgElement.remove();
                        
                        Swal.fire('Deleted!', data.message, 'success');
                    } else {
                        Swal.fire('Error!', data.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error!', 'Something went wrong!', 'error');
                }
            }
        }
    </script>
}
