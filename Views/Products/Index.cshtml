        <!-- Products Main Grid -->
        <main class="col-lg-9 col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold m-0">Our Collection</h2>
                    <p class="text-muted small">Showing @Model.Products.Count() items matching your criteria</p>
                </div>
                <div class="dropdown">
                    <button class="btn btn-light btn-sm dropdown-toggle border shadow-sm" type="button" data-bs-toggle="dropdown">
                        Sort by: Newest
                    </button>
                    <ul class="dropdown-menu shadow">
                        <li><a class="dropdown-item" href="#">Price: Low to High</a></li>
                        <li><a class="dropdown-item" href="#">Price: High to Low</a></li>
                    </ul>
                </div>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-emoji-frown display-1 text-muted"></i>
                    <h4 class="mt-3">No products found!</h4>
                    <p class="text-muted">Try adjusting your filters or search terms.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                    @foreach (var product in Model.Products)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm hover-card overflow-hidden">
                                <div class="position-relative">
                                    <img src="@product.ImageUrl" class="card-img-top"
                                         style="height: 240px; object-fit: cover;" alt="@product.Name">
                                    @if (!product.IsInStock)
                                    {
                                        <div class="position-absolute top-0 end-0 m-3 shadow">
                                            <span class="badge bg-danger">Sold Out</span>
                                        </div>
                                    }
                                </div>

                                <div class="card-body d-flex flex-column p-4">
                                    <h6 class="card-title fw-bold text-dark mb-2">@product.Name</h6>

                                    <!-- Stock Status Indicators -->
                                    <div class="mb-3">
                                        @if (product.IsInStock)
                                        {
                                            <small class="text-success"><i class="bi bi-check-circle-fill me-1"></i> In Stock</small>
                                        }
                                        else
                                        {
                                            <small class="text-danger"><i class="bi bi-x-circle-fill me-1"></i> Out of Stock</small>
                                        }
                                    </div>

                                    <div class="mt-auto">
                                        <p class="text-primary fs-5 fw-bold mb-3">@product.Price.ToString("C0")</p>

                                        <div class="d-grid gap-2">
                                            <!-- Add to Cart Button -->
                                            <button class="btn btn-primary rounded-pill py-2 @(product.IsInStock ? "" : "disabled")"
                                                    onclick="addToCart(@product.Id)">
                                                <i class="bi bi-cart-plus me-2"></i> Add to Cart
                                            </button>

                                            <!-- Details Link -->
                                            <a asp-action="Details" asp-route-id="@product.Id"
                                               class="btn btn-outline-dark btn-sm rounded-pill py-2">
                                                View Details
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>
