@using Giftify.ViewModels.Products


@model IEnumerable<ProductListItemVM>


@{
    ViewData["Title"] = "Index";
}

<h1>Products Page</h1>

<div>
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-3 gap-4">
                <div class="card">
                    <img src="@product.ImageUrl" alt="@product.Name" class="card-img-top">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Price.ToString("C2")</p>
                        <p class="card-text">@product.IsInStock</p>
                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary">Show Details</a>
                    </div>
                </div>
            </div>
        }
    </div>


</div>