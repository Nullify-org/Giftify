<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Giftify Admin</title>
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: #1a1a2e;
            --sidebar-hover: #16213e;
            --sidebar-active: #e94560;
            --topbar-height: 60px;
        }

        body { background: #f4f6fb; font-family: 'Segoe UI', sans-serif; }

        /* ── Sidebar ─────────────────────────────────── */
        #adminSidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-width); height: 100vh;
            background: var(--sidebar-bg);
            display: flex; flex-direction: column;
            z-index: 1000; transition: transform .25s ease;
            overflow-y: auto;
        }
        #adminSidebar .sidebar-brand {
            padding: 20px 24px 16px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        #adminSidebar .sidebar-brand .brand-g { color: var(--sidebar-active); font-size: 1.8rem; font-weight: 900; }
        #adminSidebar .sidebar-brand .brand-sub { color: rgba(255,255,255,.45); font-size:.7rem; letter-spacing:2px; text-transform:uppercase; }

        #adminSidebar .nav-section-title {
            font-size: .65rem; font-weight: 700; letter-spacing: 1.5px;
            text-transform: uppercase; color: rgba(255,255,255,.3);
            padding: 20px 24px 6px;
        }
        #adminSidebar .nav-link {
            color: rgba(255,255,255,.65); padding: 10px 24px;
            border-radius: 0; display: flex; align-items: center; gap: 12px;
            font-size: .9rem; transition: all .15s;
            border-left: 3px solid transparent;
        }
        #adminSidebar .nav-link:hover {
            background: var(--sidebar-hover); color: #fff;
            border-left-color: rgba(233,69,96,.4);
        }
        #adminSidebar .nav-link.active {
            background: rgba(233,69,96,.15); color: #fff;
            border-left-color: var(--sidebar-active);
        }
        #adminSidebar .nav-link i { font-size: 1rem; width: 20px; text-align: center; }

        .sidebar-footer {
            margin-top: auto; padding: 16px 24px;
            border-top: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-footer .admin-name { color: #fff; font-size: .85rem; font-weight: 600; }
        .sidebar-footer .admin-role { color: rgba(255,255,255,.4); font-size:.75rem; }

        /* ── Main content ────────────────────────────── */
        #adminMain {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex; flex-direction: column;
        }

        #adminTopbar {
            height: var(--topbar-height);
            background: #fff;
            border-bottom: 1px solid #e8eaf0;
            display: flex; align-items: center;
            padding: 0 28px; gap: 16px;
            position: sticky; top: 0; z-index: 900;
        }
        #adminTopbar .page-title { font-weight: 700; font-size: 1.1rem; color: #1a1a2e; flex: 1; }
        #adminTopbar .topbar-badge {
            background: #fff3f5; color: var(--sidebar-active);
            border: 1px solid rgba(233,69,96,.2);
            font-size: .75rem; font-weight: 600;
            padding: 4px 12px; border-radius: 20px;
        }

        #adminContent { padding: 28px; flex: 1; }

        .stat-card {
            background: #fff; border-radius: 14px;
            padding: 22px 24px; border: 1px solid #e8eaf0;
            transition: box-shadow .2s;
        }
        .stat-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.07); }
        .stat-icon {
            width: 46px; height: 46px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem;
        }

        @@media (max-width: 991px) {
            #adminSidebar { transform: translateX(-100%); }
            #adminSidebar.open { transform: translateX(0); }
            #adminMain { margin-left: 0; }
            #sidebarOverlay { display: block !important; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Overlay for mobile -->
<div id="sidebarOverlay"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:999;"
     onclick="closeSidebar()"></div>

<!-- ══ Sidebar ══════════════════════════════════════════ -->
<nav id="adminSidebar">
    <div class="sidebar-brand">
        <div><span class="brand-g">G</span><span style="color:#fff;font-weight:700;font-size:1.4rem;">iftify</span></div>
        <div class="brand-sub">Admin Panel</div>
    </div>

    <div class="nav-section-title">Overview</div>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "AdminDashboard" ? "active" : "")"
       asp-controller="AdminDashboard" asp-action="Index">
        <i class="bi bi-grid-1x2-fill"></i> Dashboard
    </a>

    <div class="nav-section-title">Catalog</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminProduct" ? "active" : "")"
       asp-controller="AdminProduct" asp-action="Index">
        <i class="bi bi-box-seam-fill"></i> Products
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCategory" ? "active" : "")"
       asp-controller="AdminCategory" asp-action="Index">
        <i class="bi bi-tag-fill"></i> Categories
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminOccasion" ? "active" : "")"
       asp-controller="AdminOccasion" asp-action="Index">
        <i class="bi bi-calendar-heart-fill"></i> Occasions
    </a>

    <div class="nav-section-title">Sales</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminOrder" ? "active" : "")"
       asp-controller="AdminOrder" asp-action="Index">
        <i class="bi bi-bag-check-fill"></i> Orders
    </a>

    <div class="nav-section-title">Users</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUser" ? "active" : "")"
       asp-controller="AdminUser" asp-action="Index">
        <i class="bi bi-people-fill"></i> Manage Users
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUser" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
       asp-controller="AdminUser" asp-action="Create">
        <i class="bi bi-person-plus-fill"></i> Add User
    </a>

    <div class="sidebar-footer">
        <div class="d-flex align-items-center gap-2">
            <div style="width:34px;height:34px;border-radius:50%;background:var(--sidebar-active);
                        display:flex;align-items:center;justify-content:center;
                        color:#fff;font-weight:700;font-size:.85rem;">
                @((User.Identity?.Name ?? "A").Substring(0, 1).ToUpper())
            </div>
            <div>
                <div class="admin-name">@(User.Identity?.Name ?? "Admin")</div>
                <div class="admin-role">Administrator</div>
            </div>
        </div>
        <form asp-action="Logout" asp-controller="Account" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="btn btn-sm w-100 text-start text-white-50 border-0 bg-transparent p-0">
                <i class="bi bi-box-arrow-left me-2"></i>Sign out
            </button>
        </form>
    </div>
</nav>

<!-- ══ Main ═════════════════════════════════════════════ -->
<div id="adminMain">

    <!-- Topbar -->
    <div id="adminTopbar">
        <button class="btn btn-sm border-0 d-lg-none me-2" onclick="openSidebar()">
            <i class="bi bi-list fs-4"></i>
        </button>
        <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>
        <span class="topbar-badge"><i class="bi bi-shield-fill-check me-1"></i>Admin</span>
        <a asp-controller="Home" asp-action="Index" target="_blank"
           class="btn btn-sm btn-outline-secondary rounded-pill ms-2">
            <i class="bi bi-eye me-1"></i>View Site
        </a>
    </div>

    <!-- Content -->
    <div id="adminContent">
        @RenderBody()
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function openSidebar() {
        document.getElementById('adminSidebar').classList.add('open');
        document.getElementById('sidebarOverlay').style.display = 'block';
    }
    function closeSidebar() {
        document.getElementById('adminSidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').style.display = 'none';
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
